* text=auto

# Keep shell and script files with LF
*.sh text eol=lf
*.bash text eol=lf

# Keep Windows command scripts with CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Common binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary
